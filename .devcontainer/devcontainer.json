{
  "name": "fortymm-api",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/api",
  "remoteUser": "vscode",
  "forwardPorts": [8000, 5432],
  "portsAttributes": {
    "8000": { "label": "FastAPI" },
    "5432": { "label": "Postgres" }
  },
  "onCreateCommand": "mise trust && mise install",
  "postCreateCommand": "uv sync",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  }
}
